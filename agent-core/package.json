{
  "name": "@firecrawl/agent-core",
  "version": "0.1.0",
  "description": "AI-powered web research agent framework built on Firecrawl",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "src/skills/definitions",
    "src/orchestrator/prompts",
    "src/worker/prompts"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ai": "^6.0.0",
    "deepagents": "^1.9.0",
    "firecrawl-aisdk": "^0.12.0",
    "gray-matter": "^4.0.3",
    "just-bash": "^2.14.0",
    "langchain": "^1.3.1",
    "papaparse": "^5.4.1",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "@langchain/anthropic": ">=1.0.0",
    "@langchain/google-genai": ">=2.0.0",
    "@langchain/openai": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/anthropic": {
      "optional": true
    },
    "@langchain/google-genai": {
      "optional": true
    },
    "@langchain/openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.39",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/openai": "^1.4.4",
    "@types/papaparse": "^5.3.15",
    "tsup": "^8.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.3"
  },
  "license": "MIT"
}
