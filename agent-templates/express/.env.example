# Required
FIRECRAWL_API_KEY=

# Model — use MODEL shorthand or MODEL_PROVIDER + MODEL_ID (default: google:gemini-3-flash-preview)
# MODEL=anthropic:claude-sonnet-4-6
# MODEL_PROVIDER=google
# MODEL_ID=gemini-3-flash-preview

# Provider API keys — set at least one matching your MODEL_PROVIDER
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional
# AI_GATEWAY_API_KEY=
# CUSTOM_OPENAI_API_KEY=
# CUSTOM_OPENAI_BASE_URL=
# CORS — opt-in. Unset = same-origin only (safe default). Set to a specific
# origin (https://app.example.com) to allow that origin, or "*" to open fully.
# CORS_ORIGIN=
# PORT=3000
# LOG=0  # disable request logging
# BODY_LIMIT=1mb  # max request body size
