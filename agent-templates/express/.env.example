# Required
FIRECRAWL_API_KEY=

# Model — use MODEL shorthand or MODEL_PROVIDER + MODEL_ID (default: google:gemini-3-flash-preview)
# MODEL=anthropic:claude-sonnet-4-6
# MODEL_PROVIDER=google
# MODEL_ID=gemini-3-flash-preview

# Provider API keys — set at least one matching your MODEL_PROVIDER
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional
# AI_GATEWAY_API_KEY=
# CUSTOM_OPENAI_API_KEY=
# CUSTOM_OPENAI_BASE_URL=
# CORS_ORIGIN=*
# PORT=3000
