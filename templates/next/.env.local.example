# Firecrawl API key (required for scrape/search/interact tools)
FIRECRAWL_API_KEY=

# AI Gateway (default provider — supports openai/gpt-5.4, anthropic/claude-sonnet-4, etc.)
AI_GATEWAY_API_KEY=

# Direct provider keys (users can override via BYOK in the UI)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
